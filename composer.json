{
  "name": "kickerscup/kickerscup",
  "description": "Ein elegantes PHP 8.4 Framework mit ADR-Muster für einen Fußballmanager",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "ext-pdo": "*",
    "ext-json": "*",
    "ext-mbstring": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "preferred-install": "dist"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}